<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RimeUserDbEditor.EntryEditWindow"
        Title="編輯詞條"
        Width="460" Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">
    <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
          ColumnDefinitions="90,*">

        <Label    Grid.Row="0" Grid.Column="0" Content="詞語"      VerticalAlignment="Center"/>
        <TextBox  Grid.Row="0" Grid.Column="1" x:Name="TextBox_"   Margin="0,4"/>
        <Label    Grid.Row="1" Grid.Column="0" Content="編碼"      VerticalAlignment="Center"/>
        <TextBox  Grid.Row="1" Grid.Column="1" x:Name="CodeBox"    Margin="0,4"/>
        <Label    Grid.Row="2" Grid.Column="0" Content="Commits (c)"   VerticalAlignment="Center"/>
        <TextBox  Grid.Row="2" Grid.Column="1" x:Name="CommitsBox" Margin="0,4"
                  ToolTip.Tip="負值代表刪除這個詞條。"/>
        <Label    Grid.Row="3" Grid.Column="0" Content="Dee (d)"   VerticalAlignment="Center"/>
        <TextBox  Grid.Row="3" Grid.Column="1" x:Name="DeeBox"     Margin="0,4"/>
        <Label    Grid.Row="4" Grid.Column="0" Content="Tick (t)"  VerticalAlignment="Center"/>
        <TextBox  Grid.Row="4" Grid.Column="1" x:Name="TickBox"    Margin="0,4"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="OkButton"     Content="確定" IsDefault="True" Margin="0,0,8,0" Click="OkButton_Click"/>
            <Button x:Name="CancelButton" Content="取消" IsCancel="True"                   Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
